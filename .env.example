# ============================================================
# .env.example — Variables de entorno del proyecto
# Copiar a .env y ajustar los valores:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gestion_academica

# --- Backend (NestJS) ---
# En Docker, el host es "db" (nombre del servicio). En local usa "localhost".
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestion_academica"
PORT=3001

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
